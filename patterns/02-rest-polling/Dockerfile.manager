FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /manager ./patterns/02-rest-polling/cmd/manager

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /manager /manager
EXPOSE 8081
ENTRYPOINT ["/manager"]
